{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "fs:default",
    "fs:allow-read-text-file",
    "fs:allow-write-text-file",
    "fs:allow-read-file",
    "fs:allow-write-file",
    "fs:allow-mkdir",
    "fs:allow-exists",
    "fs:allow-appdata-read-recursive",
    "fs:allow-appdata-write-recursive",
    "fs:read-all",
    "fs:allow-read-dir",
    "fs:allow-stat",
    "fs:allow-copy-file",
    "fs:allow-remove",
    "fs:allow-rename",
    {
      "identifier": "fs:scope",
      "allow": [
        { "path": "**" },
        { "path": "$HOME/**" },
        { "path": "$DOCUMENT/**" },
        { "path": "$DOWNLOAD/**" },
        { "path": "$PICTURE/**" },
        { "path": "$DESKTOP/**" }
      ]
    },
    "dialog:default",
    "dialog:allow-save",
    "dialog:allow-open",
    "store:default",
    "http:default",
    "http:allow-fetch",
    "http:allow-fetch-send",
    "shell:default",
    "shell:allow-open",
    "core:window:default",
    "core:window:allow-minimize",
    "core:window:allow-toggle-maximize",
    "core:window:allow-close",
    "core:window:allow-destroy",
    "core:window:allow-start-dragging",
    "core:window:allow-set-focus",
    "core:window:allow-is-maximized",
    "updater:default",
    "process:allow-restart",
    "process:allow-exit",
    "sql:default",
    "sql:allow-execute",
    "sql:allow-select",
    "sql:allow-load",
    "sql:allow-close"
  ]
}
